// Node.js + Next.js frontend starter for Person 2

// Folder structure:
// ai-dashboard/
// ├─ pages/
// │  ├─ index.tsx
// │  └─ dashboard.tsx
// ├─ types/
// │  └─ index.ts
// ├─ data/
// │  └─ mock.ts
// ├─ package.json
// └─ tsconfig.json

/* package.json */
{
  "name": "ai-dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start"
  },
  "dependencies": {
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest"
  }
}

/* tsconfig.json */
{
  "compilerOptions": {
    "target": "ES6",
    "module": "commonjs",
    "jsx": "react",
    "strict": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["pages/**/*", "types/**/*", "data/**/*"]
}

/* types/index.ts */
export interface SourceItem {
  id: string;
  sourceType: 'email' | 'pdf';
  sender?: string;
  subject?: string;
  uploadName?: string;
  extractedText: string;
}

export interface ExtractedTask {
  id: string;
  title: string;
  type: 'deadline' | 'event' | 'task';
  dueDate?: string;
  startTime?: string;
  endTime?: string;
  confidence: number;
  evidence: string;
  sourceId: string;
}

/* data/mock.ts */
import { SourceItem, ExtractedTask } from '../types';

export const mockSources: SourceItem[] = [
  {
    id: '1',
    sourceType: 'email',
    sender: 'professor@university.edu',
    subject: 'Submit financial aid form',
    extractedText: 'Please submit the form by March 14.'
  },
  {
    id: '2',
    sourceType: 'pdf',
    uploadName: 'EventSchedule.pdf',
    extractedText: 'Orientation starts on March 20 at 10:00 AM.'
  }
];

export const mockTasks: ExtractedTask[] = [
  {
    id: 'task1',
    title: 'Submit financial aid form',
    type: 'deadline',
    dueDate: '2026-03-14',
    confidence: 0.91,
    evidence: 'Please submit the form by March 14.',
    sourceId: '1'
  },
  {
    id: 'task2',
    title: 'Orientation',
    type: 'event',
    startTime: '2026-03-20T10:00:00',
    endTime: '2026-03-20T12:00:00',
    confidence: 0.95,
    evidence: 'Orientation starts on March 20 at 10:00 AM.',
    sourceId: '2'
  }
];

/* pages/index.tsx */
import { NextPage } from 'next';
import Link from 'next/link';

const Home: NextPage = () => {
  const handleConnectGoogle = () => {
    alert('Google account connected! (mock)');
  };

  return (
    <div style={{ padding: 20 }}>
      <h1>AI Dashboard Home</h1>
      <button onClick={handleConnectGoogle}>Connect Google</button>
      <p><Link href="/dashboard">Go to Dashboard</Link></p>
    </div>
  );
};

export default Home;

/* pages/dashboard.tsx */
import { NextPage } from 'next';
import { mockTasks } from '../data/mock';
import { ExtractedTask } from '../types';

const Dashboard: NextPage = () => {
  const handleApprove = (id: string) => alert(`Approved task ${id}`);
  const handleDismiss = (id: string) => alert(`Dismissed task ${id}`);

  return (
    <div style={{ padding: 20 }}>
      <h1>Needs Review Dashboard</h1>
      {mockTasks.map((task: ExtractedTask) => (
        <div key={task.id} style={{ border: '1px solid gray', margin: 10, padding: 10 }}>
          <h2>{task.title} ({task.type})</h2>
          <p>Due: {task.dueDate || task.startTime}</p>
          <p>Confidence: {Math.round(task.confidence * 100)}%</p>
          <p>Evidence: {task.evidence}</p>
          <button onClick={() => handleApprove(task.id)}>Approve</button>
          <button onClick={() => handleDismiss(task.id)}>Dismiss</button>
        </div>
      ))}
    </div>
  );
};

export default Dashboard;

